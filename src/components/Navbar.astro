---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/showcases', label: 'Showcases' },
  { href: '/mentors', label: 'Mentors' },
  { href: '/batches', label: 'Batches' },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <span class="text-2xl font-bold text-indigo-600">CCIT</span>
          <span class="text-2xl font-semibold text-slate-900">Venture Studio</span>
        </a>
      </div>
      
      <div class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${
              currentPath === item.href
                ? 'text-indigo-600 bg-indigo-50'
                : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>
      
      <div class="flex md:hidden">
        <button
          id="mobile-menu-button"
          type="button"
          class="p-2 rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-100"
          aria-label="Toggle menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white">
    <div class="px-4 py-2 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${
            currentPath === item.href
              ? 'text-indigo-600 bg-indigo-50'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
          }`}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
