---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const batches = await getCollection('batches');
const sortedBatches = batches.sort((a, b) => b.data.batchNumber - a.data.batchNumber);

const statusColors = {
  'Active': 'bg-green-100 text-green-800',
  'Completed': 'bg-slate-100 text-slate-600',
  'Upcoming': 'bg-blue-100 text-blue-800',
};

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('id-ID', {
    month: 'long',
    year: 'numeric'
  }).format(date);
};
---

<Layout title="Batches" description="Riwayat program CCIT Venture Studio">
  <Navbar />
  
  <main class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-mono text-indigo-600 font-medium mb-4">PROGRAM HISTORY</p>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Riwayat Batch
        </h1>
        
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Perjalanan CCIT Venture Studio dari waktu ke waktu. 
          Setiap batch menghasilkan produk-produk inovatif dari mahasiswa berbakat.
        </p>
      </div>

      {sortedBatches.length === 0 ? (
        <div class="text-center py-20">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Belum Ada Batch</h3>
          <p class="text-slate-600">Informasi batch akan segera ditampilkan di sini.</p>
        </div>
      ) : (
        <div class="space-y-6 max-w-4xl mx-auto">
          {sortedBatches.map((batch) => (
            <a href={`/batches/${batch.slug}`} class="card card-hover block overflow-hidden">
              <div class="p-6">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                  <div class="flex items-center gap-4">
                    <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0">
                      <span class="text-xl font-bold text-indigo-600">
                        #{batch.data.batchNumber}
                      </span>
                    </div>
                    
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-slate-900 truncate">
                        {batch.data.name}
                      </h3>
                      <p class="text-slate-500 font-mono text-sm">
                        {formatDate(batch.data.startDate)} - {formatDate(batch.data.endDate)}
                      </p>
                    </div>
                  </div>
                  
                  <span class={`badge ${statusColors[batch.data.status]} flex-shrink-0`}>
                    {batch.data.status}
                  </span>
                </div>
                
                <p class="text-slate-600 mb-4 leading-relaxed line-clamp-2">
                  {batch.data.description}
                </p>
                
                <div class="flex items-center gap-4 pt-4 border-t border-slate-100">
                  {batch.data.totalProjects && (
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                      </svg>
                      <span class="text-sm text-slate-700 font-medium">
                        {batch.data.totalProjects} Proyek
                      </span>
                    </div>
                  )}
                  
                  {batch.data.students && (
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                      </svg>
                      <span class="text-sm text-slate-700 font-medium">
                        {batch.data.students.length} Mahasiswa
                      </span>
                    </div>
                  )}
                  
                  <div class="ml-auto flex items-center text-indigo-600 text-sm font-medium">
                    Lihat Detail
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>
        
        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
