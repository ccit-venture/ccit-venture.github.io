---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

// Get all batches for static paths
export async function getStaticPaths() {
  const batches = await getCollection('batches');
  return batches.map((batch) => ({
    params: { slug: batch.id },
    props: { batch },
  }));
}

const { batch } = Astro.props;

// Get all showcases and filter by batch
const allShowcases = await getCollection('showcases');
const batchShowcases = allShowcases.filter(
  (showcase) => showcase.data.batch === `Batch ${batch.data.batchNumber}`
);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('id-ID', {
    month: 'long',
    year: 'numeric'
  }).format(date);
};

const statusColors = {
  'Active': 'bg-green-100 text-green-800',
  'Completed': 'bg-slate-100 text-slate-600',
  'Upcoming': 'bg-blue-100 text-blue-800',
};

const projectStatusColors = {
  'Idea Validation': 'bg-green-100 text-green-800',
  'Development': 'bg-slate-100 text-slate-600',
  'Beta Release': 'bg-blue-100 text-blue-800',
};
---

<Layout 
  title={`${batch.data.name} - Batch ${batch.data.batchNumber}`} 
  description={batch.data.description}>
  <Navbar />
  
  <main class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <a href="/batches" class="text-slate-500 hover:text-indigo-600 flex items-center text-sm">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Kembali ke Batches
        </a>
      </nav>

      <!-- Batch Header -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 bg-indigo-100 rounded-xl flex items-center justify-center">
            <span class="text-3xl font-bold text-indigo-600">
              #{batch.data.batchNumber}
            </span>
          </div>
          
          <div>
            <p class="text-sm font-mono text-indigo-600 font-medium">BATCH {batch.data.batchNumber}</p>
            <h1 class="text-4xl md:text-5xl font-bold text-slate-900">
              {batch.data.name}
            </h1>
          </div>
        </div>
        
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <span class={`badge ${statusColors[batch.data.status]}`}>
            {batch.data.status}
          </span>
          
          <span class="text-slate-500 font-mono text-sm">
            {formatDate(batch.data.startDate)} - {formatDate(batch.data.endDate)}
          </span>
          
          {batch.data.totalProjects && (
            <span class="text-slate-600 text-sm">
              <span class="font-semibold">{batch.data.totalProjects}</span> Proyek
            </span>
          )}
          
          {batch.data.students && (
            <span class="text-slate-600 text-sm">
              <span class="font-semibold">{batch.data.students.length}</span> Mahasiswa
            </span>
          )}
        </div>
        
        <p class="text-xl text-slate-600 max-w-3xl">
          {batch.data.description}
        </p>
      </div>

      <!-- Projects Section -->
      {batch.data.projects && batch.data.projects.length > 0 && (
        <section class="mb-16">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900">Proyek Batch Ini</h2>
          </div>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {batch.data.projects.map((project) => (
              <div class="card card-hover group block overflow-hidden">
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class={`badge ${
                      project.status === 'Active' ? 'bg-green-100 text-green-800' :
                      project.status === 'Completed' ? 'bg-slate-100 text-slate-600' :
                      'bg-blue-100 text-blue-800'
                    }`}>
                      {project.status}
                    </span>
                  </div>
                  
                  <h3 class="text-xl font-bold text-slate-900 mb-2">{project.name}</h3>
                  
                  <p class="text-slate-600 text-sm mb-3">{project.tagline}</p>
                  
                  <p class="text-slate-500 text-xs line-clamp-2 group-hover:line-clamp-none transition-all">{project.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Students Section -->
      {batch.data.students && batch.data.students.length > 0 && (
        <section>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900">Daftar Mahasiswa</h2>
          </div>
          
          <div class="card overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-200">
                  <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">No</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Nama</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">NIM</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Kelas</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Kelompok</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">Angkatan</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                  {batch.data.students.map((student, index) => (
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-6 py-4 text-sm text-slate-500">{index + 1}</td>
                      <td class="px-6 py-4">
                        <div class="text-sm font-medium text-slate-900">{student.name}</div>
                      </td>
                      <td class="px-6 py-4 text-sm text-slate-600 font-mono">{student.nim}</td>
                      <td class="px-6 py-4">
                        <span class="badge badge-fsd">{student.class}</span>
                      </td>
                      <td class="px-6 py-4 text-sm text-slate-700">{student.group}</td>
                      <td class="px-6 py-4 text-sm text-slate-600">{student.year}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )}
    </div>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>
        
        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
