---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

const categories = [
  {
    id: 'product-development',
    name: 'Product Development',
    description: 'Learn to build products from ideation to MVP with structured curriculum. Includes theory, frameworks, and real product breakdowns.',
    icon: '🚀',
    color: 'from-indigo-500 to-purple-500',
    curriculumCount: 2,
  },
];

const categoryIcons: Record<string, string> = {
  'product-development': `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
  </svg>`,
};
---

<Layout title="Learning Modules - CCIT Venture Studio">
  <Navbar />
  <main class="min-h-screen bg-slate-50">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white border-b border-slate-200">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-white to-slate-50"></div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-indigo-100 text-indigo-700 text-sm font-mono font-medium mb-6">
            <span class="w-2 h-2 bg-indigo-600 rounded-full mr-2 animate-pulse"></span>
            Structured Learning Paths
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 leading-tight">
            Learning
            <span class="text-indigo-600">Modules</span>
          </h1>
          
          <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
            Structured curriculums designed to help you master product development and AI-powered coding
          </p>
        </div>
      </div>
    </section>

    <!-- Categories Grid -->
    <section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-1 lg:grid-cols-2 gap-8">
          {categories.map((category) => (
            <a
              href={`/module/${category.id}`}
              class="group relative bg-gradient-to-br from-white via-white to-slate-50 rounded-3xl border border-slate-200 overflow-hidden hover:border-indigo-400 hover:shadow-2xl transition-all duration-500"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              
              <div class="relative p-10 lg:p-12">
                <div class="flex items-start justify-between mb-8">
                  <div class:list={[
                    'w-20 h-20 rounded-3xl flex items-center justify-center text-white font-bold text-3xl shadow-lg',
                    'bg-gradient-to-br',
                    category.color
                  ]}>
                    {category.icon}
                  </div>
                  
                  <div class="flex flex-col items-end gap-2">
                    {category.curriculumCount > 0 ? (
                      <span class="inline-flex items-center px-4 py-2 rounded-full bg-gradient-to-r from-indigo-500 to-purple-500 text-white text-sm font-semibold shadow-md">
                        {category.curriculumCount} Curriculum{category.curriculumCount !== 1 ? 's' : ''}
                      </span>
                    ) : (
                      <span class="inline-flex items-center px-4 py-2 rounded-full bg-slate-200 text-slate-600 text-sm font-semibold">
                        Coming soon
                      </span>
                    )}
                  </div>
                </div>

                <h3 class="text-3xl font-bold text-slate-900 mb-4 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-indigo-600 group-hover:to-purple-600 transition-all">
                  {category.name}
                </h3>
                
                <p class="text-slate-600 mb-8 leading-relaxed text-lg">
                  {category.description}
                </p>

                <div class="flex items-center text-indigo-600 font-semibold text-lg group-hover:translate-x-2 transition-transform">
                  <span>Start Learning</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Info Section -->
    <section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-8 bg-white border-t border-slate-200">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">Why Structured Modules?</h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Our modules are designed with real-world application in mind
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto bg-indigo-100 rounded-2xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Step-by-Step</h3>
            <p class="text-slate-600">
              Progressive learning path from fundamentals to advanced concepts
            </p>
          </div>

          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto bg-indigo-100 rounded-2xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Hands-on Practice</h3>
            <p class="text-slate-600">
              Learn by doing with practical exercises and real projects
            </p>
          </div>

          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto bg-indigo-100 rounded-2xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Expert Guidance</h3>
            <p class="text-slate-600">
              Content curated by industry experts and successful founders
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>

        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>