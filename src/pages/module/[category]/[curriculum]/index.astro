---
import { getCollection, render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';

export async function getStaticPaths() {
  const modules = await getCollection('modules');
  
  // Get all unique curriculum ids
  const curriculumIds = new Set<string>();
  
  modules.forEach(moduleItem => {
    const idParts = moduleItem.id.split('/');
      if (idParts.length >= 2 && moduleItem.data.type === 'curriculum') {
      // This is a curriculum index
      const category = 'product-development';
      const curriculumName = idParts[idParts.length - 1];
      curriculumIds.add(`${category}/${curriculumName}`);
    }
  });
  
  return Array.from(curriculumIds).map(id => {
    const [category, curriculum] = id.split('/');
    return {
      params: { category, curriculum },
      props: { curriculumId: id }
    };
  });
}

const { category, curriculum } = Astro.params;
const { curriculumId } = Astro.props;

const allModules = await getCollection('modules');

// Get curriculum index
const curriculumIndex = allModules.find(m => {
  const idParts = m.id.split('/');
  return m.data.type === 'curriculum' && 
         idParts[idParts.length - 1] === curriculum;
});

// Get all lessons for this curriculum
const lessons = allModules
  .filter(m => {
    const idParts = m.id.split('/');
    return m.data.type === 'lesson' && 
           idParts.length >= 3 && 
           idParts[1] === curriculum;
  })
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categoryInfo: Record<string, { name: string; color: string; gradient: string }> = {
  'product-development': {
    name: 'Product Development',
    color: 'indigo',
    gradient: 'from-indigo-500 to-purple-500'
  }
};

const info = categoryInfo[category] || {
  name: category,
  color: 'slate',
  gradient: 'from-slate-500 to-gray-500'
};

const difficultyColors: Record<string, string> = {
  'Beginner': 'bg-emerald-100 text-emerald-800',
  'Intermediate': 'bg-amber-100 text-amber-800',
  'Advanced': 'bg-rose-100 text-rose-800',
};

// Fallback if curriculum index not found
const curriculumData = curriculumIndex?.data || {
  title: curriculum.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
  description: 'Complete learning curriculum',
  difficulty: 'Beginner',
  author: 'CCIT Venture Studio Team',
  estimatedTime: 'TBD'
};

// Calculate total content
const { Content } = curriculumIndex ? await render(curriculumIndex) : { Content: null };
---

<Layout title={`${curriculumData.title} - CCIT Venture Studio`}>
  <Navbar />
  <main class="min-h-screen bg-slate-50">
    <!-- Hero Section -->
    <section class:list={['py-12 lg:py-16', 'bg-gradient-to-br', info.gradient]}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-6">
          <a href={`/module/${category}`} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to {info.name}
          </a>
        </div>

        <div class="text-white">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class:list={[
              'px-4 py-1.5 rounded-full text-sm font-semibold shadow-sm',
              difficultyColors[curriculumData.difficulty] || 'bg-white/20 backdrop-blur-sm text-white'
            ]}>
              {curriculumData.difficulty}
            </span>
            
            <span class="px-4 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-sm font-semibold shadow-sm">
              📚 Curriculum
            </span>
            
            {curriculumData.estimatedTime && (
              <span class="px-4 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-sm font-semibold shadow-sm flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {curriculumData.estimatedTime}
              </span>
            )}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 drop-shadow-lg">{curriculumData.title}</h1>
          
          <div class="max-w-3xl">
            <p class="text-lg md:text-xl text-white font-medium mb-4 drop-shadow-md leading-relaxed">
              {curriculumData.description}
            </p>
          </div>
          
          <div class="flex flex-wrap items-center gap-6 text-sm">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              By {curriculumData.author}
            </div>
            
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(curriculumData.pubDate).toLocaleDateString('id-ID', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <!-- Lessons List -->
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100">
              <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold text-slate-900">Course Content</h2>
                <span class="text-sm text-slate-500">{lessons.length} Lessons</span>
              </div>
            </div>

            {lessons.length === 0 ? (
              <div class="p-12 text-center">
                <div class="text-6xl mb-4">📝</div>
                <p class="text-slate-600">Lessons will be added soon!</p>
              </div>
            ) : (
              <div class="divide-y divide-slate-100">
                {lessons.map((lesson, index) => {
                  const idParts = lesson.id.split('/');
                  const lessonId = idParts[idParts.length - 1];
                  return (
                    <a
                      href={`/module/${category}/${curriculum}/${lessonId}`}
                      class="group flex items-start gap-4 p-6 hover:bg-slate-50 transition-colors"
                    >
                      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 text-white flex items-center justify-center font-bold text-sm">
                        {index + 1}
                      </div>
                      
                      <div class="flex-1 min-w-0">
                        <h3 class="text-base font-semibold text-slate-900 mb-1 group-hover:text-indigo-600 transition-colors">
                          {lesson.data.title}
                        </h3>
                        
                        <p class="text-sm text-slate-600 mb-2 line-clamp-1">{lesson.data.description}</p>
                        
                        <div class="flex items-center gap-4 text-xs text-slate-500">
                          {lesson.data.estimatedTime && (
                            <span class="flex items-center gap-1">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              {lesson.data.estimatedTime}
                            </span>
                          )}
                          
                          <span class:list={[
                            'px-2 py-0.5 rounded-full text-xs font-medium',
                            difficultyColors[lesson.data.difficulty] || 'bg-slate-100 text-slate-600'
                          ]}>
                            {lesson.data.difficulty}
                          </span>
                        </div>
                      </div>

                      <div class="flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </div>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Prerequisites Card -->
          {curriculumData.prerequisites && curriculumData.prerequisites.length > 0 && (
            <div class="bg-white rounded-2xl border border-slate-200 p-6">
              <div class="h-1 bg-gradient-to-r from-indigo-500 to-purple-500 -mx-6 -mt-6 mb-4 rounded-t-2xl"></div>
              
              <h4 class="font-semibold text-slate-900 mb-3">Prerequisites</h4>
              
              <ul class="space-y-2">
                {curriculumData.prerequisites.map((prereq) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {prereq}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Overview Card -->
          {Content && (
            <div class="bg-white rounded-2xl border border-slate-200 p-6 max-h-[500px] overflow-y-auto">
              <div class="h-1 bg-gradient-to-r from-indigo-500 to-purple-500 -mx-6 -mt-6 mb-4 rounded-t-2xl"></div>
              
              <h4 class="font-semibold text-slate-900 mb-3">Overview</h4>
              
              <article class="prose prose-sm prose-slate max-w-none
                prose-headings:text-slate-900
                prose-headings:font-bold
                prose-headings:text-base
                prose-p:text-slate-600 prose-p:mb-3 prose-p:text-sm
                prose-ul:list-disc prose-ul:ml-4 prose-ul:mb-3
                prose-ol:list-decimal prose-ol:ml-4 prose-ol:mb-3
                prose-li:text-slate-600 prose-li:mb-1 prose-li:text-sm"
              >
                <Content />
              </article>
            </div>
          )}

          <!-- Start Learning CTA -->
          {lessons.length > 0 && (
            <div class="bg-gradient-to-br from-indigo-500 to-purple-500 rounded-2xl p-6 text-white">
              <h4 class="font-semibold mb-2">Ready to start?</h4>
              <p class="text-sm text-white/80 mb-4">
                Begin your learning journey with the first lesson.
              </p>
              
              <a
                href={`/module/${category}/${curriculum}/${lessons[0].id.split('/').pop()}`}
                class="inline-flex items-center justify-center w-full px-4 py-3 bg-white text-indigo-600 font-semibold rounded-lg hover:bg-slate-50 transition-colors"
              >
                Start First Lesson
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
          )}

          <!-- Tags -->
          {curriculumData.tags && curriculumData.tags.length > 0 && (
            <div class="bg-white rounded-2xl border border-slate-200 p-6">
              <h4 class="font-semibold text-slate-900 mb-3">Tags</h4>
              
              <div class="flex flex-wrap gap-2">
                {curriculumData.tags.map((tag) => (
                  <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-sm">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
