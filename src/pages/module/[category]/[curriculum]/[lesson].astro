---
import { getCollection, render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';

export async function getStaticPaths() {
  const modules = await getCollection('modules');
  
  return modules
    .filter(m => m.data.type === 'lesson')
    .map((lesson) => {
      // In Astro 5, id is the relative path: "product-development/product-development-2026/01-create-product-plan-one-pager"
      const idParts = lesson.id.split('/');
      
      if (idParts.length < 3) {
        console.log('Skipping lesson with invalid id:', lesson.id);
        return null;
      }
      
      const category = 'product-development';
      const curriculum = idParts[1];
      const lessonId = idParts[2];
      
      return {
        params: { 
          category,
          curriculum,
          lesson: lessonId
        },
        props: { lesson }
      };
    }).filter(Boolean);
}

const { lesson } = Astro.props;
const { category, curriculum } = Astro.params;

const { Content } = await render(lesson);

// Get curriculum info
let curriculumInfo = null;
if (curriculum) {
  const allModules = await getCollection('modules');
  curriculumInfo = allModules.find(m => 
    m.data.type === 'curriculum' && 
    m.id.includes(curriculum)
  );
}

// Get all lessons for navigation
const allModules = await getCollection('modules');
const lessons = allModules
  .filter(m => {
    const idParts = m.id.split('/');
    return m.data.type === 'lesson' && 
           idParts.length >= 3 && 
           idParts[1] === curriculum;
  })
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const currentIndex = lessons.findIndex(l => l.id === lesson.id);
const prevLesson = currentIndex > 0 ? lessons[currentIndex - 1] : null;
const nextLesson = currentIndex < lessons.length - 1 ? lessons[currentIndex + 1] : null;

const categoryInfo = {
  'product-development': {
    name: 'Product Development',
    color: 'indigo',
    gradient: 'from-indigo-500 to-purple-500'
  }
};

const info = categoryInfo[category] || { 
  name: category, 
  color: 'slate',
  gradient: 'from-slate-500 to-gray-500'
};

const difficultyColors = {
  'Beginner': 'bg-emerald-100 text-emerald-800',
  'Intermediate': 'bg-amber-100 text-amber-800',
  'Advanced': 'bg-rose-100 text-rose-800',
};

const backUrl = `/module/${category}/${curriculum}`;
const backLabel = `Back to ${curriculumInfo?.data.title || curriculum}`;
---

<Layout title={`${lesson.data.title} - CCIT Venture Studio`}>
  <Navbar />
  <main class="min-h-screen bg-slate-50">
    <!-- Hero Section -->
    <section class:list={['py-12 lg:py-16', 'bg-gradient-to-br', info.gradient]}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-6">
          <a href={backUrl} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            {backLabel}
          </a>
        </div>

        <div class="text-white">
          {lesson.data.order && (
            <div class="mb-4">
              <span class="inline-flex items-center px-3 py-1 bg-white/20 backdrop-blur-sm rounded-full text-sm font-medium">
                Lesson {lesson.data.order} of {lessons.length}
              </span>
            </div>
          )}
          
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class:list={[
              'px-3 py-1 rounded-full text-sm font-medium',
              difficultyColors[lesson.data.difficulty] || 'bg-white/20 backdrop-blur-sm text-white'
            ]}>
              {lesson.data.difficulty}
            </span>
          </div>
          
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{lesson.data.title}</h1>
          
          <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-6 leading-relaxed">{lesson.data.description}</p>
          
          <div class="flex flex-wrap items-center gap-6 text-sm">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {lesson.data.author}
            </div>
            
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(lesson.data.pubDate).toLocaleDateString('id-ID', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </div>
            
            {lesson.data.estimatedTime && (
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {lesson.data.estimatedTime}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid lg:grid-cols-4 gap-8">
        <!-- Sidebar Navigation -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-2xl border border-slate-200 p-6 sticky top-24">
            <h4 class="font-semibold text-slate-900 mb-4">Course Content</h4>
            
            <div class="space-y-2">
              {lessons.map((l, index) => {
                const isActive = l.id === lesson.id;
                const idParts = l.id.split('/');
                const lessonId = idParts[idParts.length - 1];
                
                return (
                  <a
                    href={`/module/${category}/${curriculum}/${lessonId}`}
                    class:list={[
                      'flex items-center gap-3 p-3 rounded-lg text-sm transition-colors',
                      isActive 
                        ? 'bg-indigo-50 text-indigo-700 border border-indigo-200' 
                        : 'text-slate-600 hover:bg-slate-50'
                    ]}
                  >
                    <span class:list={[
                      'flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium',
                      isActive 
                        ? 'bg-indigo-600 text-white' 
                        : 'bg-slate-100 text-slate-500'
                    ]}>
                      {index + 1}
                    </span>
                    
                    <span class="line-clamp-2">{l.data.title}</span>
                  </a>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-3">
          <!-- Prerequisites Alert -->
          {lesson.data.prerequisites && lesson.data.prerequisites.length > 0 && (
            <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-8">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                
                <div>
                  <h4 class="font-semibold text-amber-900 mb-2">Prerequisites</h4>
                  
                  <ul class="space-y-1">
                    {lesson.data.prerequisites.map((prereq) => (
                      <li class="flex items-center gap-2 text-sm text-amber-800">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {prereq}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          )}

          <!-- Lesson Content -->
          <div class="bg-white rounded-2xl border border-slate-200 p-8 lg:p-12 mb-8">
            <div class="h-1 bg-gradient-to-r from-indigo-500 to-purple-500 -mx-8 -mt-8 mb-8 rounded-t-2xl lg:-mx-12 lg:-mt-12"></div>
            
            <article class="prose prose-slate prose-lg max-w-none
              prose-headings:text-slate-900
              prose-headings:font-bold
              prose-p:text-slate-600 prose-p:mb-4 prose-p:leading-relaxed
              prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:underline
              prose-strong:text-slate-900 prose-strong:font-semibold
              prose-code:text-indigo-700 prose-code:bg-indigo-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-medium
              prose-blockquote:border-l-4 prose-blockquote:border-indigo-500 prose-blockquote:bg-indigo-50/50 prose-blockquote:pl-5 prose-blockquote:py-3 prose-blockquote:pr-5 prose-blockquote:rounded-r-lg prose-blockquote:mb-6
              prose-ul:list-disc prose-ul:ml-6 prose-ul:mb-4
              prose-ol:list-decimal prose-ol:ml-6 prose-ol:mb-4
              prose-li:text-slate-600 prose-li:mb-2
              prose-table:w-full prose-table:border-collapse prose-table:mb-6 prose-table:rounded-lg prose-table:overflow-hidden
              prose-th:bg-slate-100 prose-th:text-slate-900 prose-th:font-semibold prose-th:p-3 prose-th:text-left prose-th:border prose-th:border-slate-200
              prose-td:p-3 prose-td:border prose-td:border-slate-200 prose-td:text-slate-600
              prose-img:rounded-xl prose-img:border prose-img:border-slate-200 prose-img:mb-6 prose-img:shadow-sm
              [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-sm [&_pre_code]:leading-relaxed"
            >
              <Content />
            </article>
          </div>

          <!-- Tags -->
          {lesson.data.tags && lesson.data.tags.length > 0 && (
            <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-8">
              <h4 class="font-semibold text-slate-900 mb-3">Tags</h4>
              
              <div class="flex flex-wrap gap-2">
                {lesson.data.tags.map((tag) => (
                  <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-sm">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Navigation -->
          <div class="flex items-center justify-between">
            {prevLesson ? (
              <a
                href={`/module/${category}/${curriculum}/${prevLesson.id.split('/').pop()}`}
                class="inline-flex items-center gap-2 px-6 py-3 bg-white border border-slate-200 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Previous Lesson
              </a>
            ) : (
              <div />
            )}

            {nextLesson ? (
              <a
                href={`/module/${category}/${curriculum}/${nextLesson.id.split('/').pop()}`}
                class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                Next Lesson
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ) : (
              <div />
            )}
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
