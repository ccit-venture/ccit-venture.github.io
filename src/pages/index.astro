---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const batches = await getCollection('batches');
const sortedBatches = batches.sort((a, b) => b.data.batchNumber - a.data.batchNumber);
const latestBatch = sortedBatches[0];

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('id-ID', {
    month: 'long',
    year: 'numeric'
  }).format(date);
};

const statusColors = {
  'Active': 'bg-green-100 text-green-800',
  'Completed': 'bg-slate-100 text-slate-600',
  'Upcoming': 'bg-blue-100 text-blue-800',
};
---

<Layout title="Home">
  <Navbar />
  
  <main>
    <section class="relative overflow-hidden bg-white">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-white to-slate-50"></div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
        <div class="text-center max-w-4xl mx-auto">
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-indigo-100 text-indigo-700 text-sm font-mono font-medium mb-8">
            <span class="w-2 h-2 bg-indigo-600 rounded-full mr-2 animate-pulse"></span>
            Batch 1: Maret - Agustus 2026
          </div>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-slate-900 mb-8 leading-tight">
            Building the next
            <span class="text-indigo-600">generation</span>
            of digital founders
          </h1>
          
          <p class="text-xl md:text-2xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed">
            CCIT Venture Studio bukan sekadar program perkuliahan. Kami adalah 
            inkubator yang mengubah ide mahasiswa menjadi produk digital yang siap 
            bersaing di pasar.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/showcases" class="btn-primary">
              Lihat Showcases
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/mentors" class="btn-secondary">
              Kenali Mentors
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Visi Kami
          </h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Lebih dari sekadar pembelajaran teori, kami fokus pada <span class="font-semibold text-indigo-600">inkubasi nyata</span> 
            yang menghasilkan produk berkualitas.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="card p-8 text-center">
            <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Inkubasi Intensif</h3>
            <p class="text-slate-600">
              6 bulan program intensif dengan mentoring langsung dari Lead Engineer 
              dan berbagai expert industri.
            </p>
          </div>

          <div class="card p-8 text-center">
            <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Kolaborasi Tim</h3>
            <p class="text-slate-600">
              Mahasiswa dari berbagai jurusan (FSD, ISA, DCM) bekerja sama 
              membangun produk end-to-end.
            </p>
          </div>

          <div class="card p-8 text-center">
            <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-6">
              <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Real-World Impact</h3>
            <p class="text-slate-600">
              Setiap proyek ditujukan untuk menyelesaikan masalah nyata, 
              bukan sekadar tugas akademik.
            </p>
          </div>
        </div>
      </div>
    </section>

    {latestBatch && (
      <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-end mb-12">
            <div>
              <p class="text-sm font-mono text-indigo-600 font-medium mb-2">CURRENT BATCH</p>
              <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Latest Batch</h2>
            </div>
            <a href="/batches" class="text-indigo-600 font-medium hover:text-indigo-700 flex items-center">
              Lihat Semua Batch
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <div class="card card-hover overflow-hidden max-w-4xl mx-auto">
            <div class="p-8">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="text-2xl font-bold text-indigo-600">
                      #{latestBatch.data.batchNumber}
                    </span>
                  </div>
                  
                  <div>
                    <h3 class="text-2xl font-bold text-slate-900">
                      {latestBatch.data.name}
                    </h3>
                    <p class="text-slate-500 font-mono text-sm">
                      {formatDate(latestBatch.data.startDate)} - {formatDate(latestBatch.data.endDate)}
                    </p>
                  </div>
                </div>
                
                <span class={`badge ${statusColors[latestBatch.data.status]} flex-shrink-0`}>
                  {latestBatch.data.status}
                </span>
              </div>
              
              <p class="text-slate-600 mb-6 leading-relaxed text-lg">
                {latestBatch.data.description}
              </p>
              
              <div class="flex items-center gap-6 pt-6 border-t border-slate-100">
                {latestBatch.data.totalProjects && (
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span class="text-slate-700 font-medium">
                      {latestBatch.data.totalProjects} Proyek
                    </span>
                  </div>
                )}
                
                {latestBatch.data.students && (
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <span class="text-slate-700 font-medium">
                      {latestBatch.data.students.length} Mahasiswa
                    </span>
                  </div>
                )}
                
                <div class="ml-auto">
                  <a href={`/batches/${latestBatch.id}`} class="inline-flex items-center text-indigo-600 font-medium hover:text-indigo-700">
                    Lihat Detail
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <section class="py-20 bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Program Khusus Mahasiswa CCIT
        </h2>
        <p class="text-xl text-slate-300 mb-8 max-w-3xl mx-auto leading-relaxed">
          CCIT Venture Studio adalah program inkubasi yang <span class="font-semibold text-white">khusus untuk mahasiswa aktif CCIT semester 2 dan 4</span>. 
          Program ini tidak terbuka untuk umum. Jika Anda ingin bergabung, pastikan Anda sudah terdaftar sebagai 
          <span class="font-semibold text-white">mahasiswa aktif di CCIT</span>.
        </p>

        <a href="https://ccit.eng.ui.ac.id" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-8 py-4 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors duration-200">
          Kunjungi Website CCIT
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>
        
        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
