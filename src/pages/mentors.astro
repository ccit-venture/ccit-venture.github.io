---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';

const mentors = await getCollection('mentors');
const regularMentors = mentors.filter(m => m.data.type !== 'guest').sort((a, b) => a.data.order - b.data.order);
const guestMentors = mentors.filter(m => m.data.type === 'guest').sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Mentors" description="Kenali mentor-mentor berpengalaman di CCIT Venture Studio">
  <Navbar />

  <main class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-mono text-indigo-600 font-medium mb-4">OUR MENTORS</p>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Tim Mentor
        </h1>

        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Dibimbing oleh para profesional berpengalaman dari industri
          yang berdedikasi membantu mahasiswa mengembangkan produk terbaik.
        </p>
      </div>

      <!-- Regular Mentors Section -->
      <section class="mb-20">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900">Mentor Tetap</h2>
          <span class="text-sm text-slate-500">Mentor yang mendampingi batch secara berkala</span>
        </div>

        {regularMentors.length === 0 ? (
          <div class="text-center py-12">
            <p class="text-slate-600">Belum ada mentor tetap yang ditambahkan.</p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {regularMentors.map((mentor) => (
              <article class="card card-hover group overflow-hidden flex flex-col">
                <div class="p-5">
                  <div class="flex items-start gap-4">
                    <div class="flex-shrink-0">
                      {mentor.data.image ? (
                        <img
                          src={mentor.data.image}
                          alt={mentor.data.name}
                          class="w-16 h-16 rounded-full object-cover border-2 border-indigo-100"
                        />
                      ) : (
                        <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center border-2 border-indigo-50">
                          <span class="text-xl font-bold text-indigo-600">
                            {mentor.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                          </span>
                        </div>
                      )}
                    </div>

                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-mono text-indigo-600 font-medium mb-0.5">
                        {mentor.data.role}
                      </p>

                      <h3 class="text-lg font-bold text-slate-900 leading-tight mb-0.5">
                        {mentor.data.name}
                      </h3>

                      <p class="text-sm text-slate-500">
                        {mentor.data.title}
                      </p>
                    </div>
                  </div>

                  <div class="mt-4">
                    <p class="text-sm text-slate-600 leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all">
                      {mentor.data.bio}
                    </p>

                    <div class="flex flex-wrap gap-2 mt-4">
                      {mentor.data.linkedin && (
                        <a
                          href={mentor.data.linkedin}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                          LinkedIn
                        </a>
                      )}

                      {mentor.data.github && (
                        <a
                          href={mentor.data.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                          </svg>
                          GitHub
                        </a>
                      )}

                      {mentor.data.email && (
                        <a
                          href={`mailto:${mentor.data.email}`}
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                          </svg>
                          Email
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>

      <!-- Guest Mentors Section -->
      <section>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900">Guest Mentor</h2>
          <span class="text-sm text-slate-500">Mentor industri yang diundang berkala</span>
        </div>

        {guestMentors.length === 0 ? (
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-2xl border border-amber-200 p-12 text-center">
            <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Guest Mentor Akan Segera Diundang</h3>
            <p class="text-slate-600 max-w-lg mx-auto">
              Para profesional industri yang berpengalaman akan diundang secara berkala untuk berbagi wawasan dan materi praktis terkait pengembangan produk dan startup.
            </p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {guestMentors.map((mentor) => (
              <article class="card card-hover group overflow-hidden flex flex-col border-amber-200">
                <div class="h-1 bg-gradient-to-r from-amber-400 to-orange-400"></div>
                <div class="p-5">
                  <div class="flex items-start gap-4">
                    <div class="flex-shrink-0">
                      {mentor.data.image ? (
                        <img
                          src={mentor.data.image}
                          alt={mentor.data.name}
                          class="w-16 h-16 rounded-full object-cover border-2 border-amber-200"
                        />
                      ) : (
                        <div class="w-16 h-16 rounded-full bg-amber-100 flex items-center justify-center border-2 border-amber-50">
                          <span class="text-xl font-bold text-amber-600">
                            {mentor.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                          </span>
                        </div>
                      )}
                    </div>

                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-0.5">
                        <p class="text-xs font-mono text-amber-600 font-medium">
                          {mentor.data.role}
                        </p>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">
                          Guest
                        </span>
                      </div>

                      <h3 class="text-lg font-bold text-slate-900 leading-tight mb-0.5">
                        {mentor.data.name}
                      </h3>

                      <p class="text-sm text-slate-500">
                        {mentor.data.title}
                      </p>
                    </div>
                  </div>

                  <div class="mt-4">
                    <p class="text-sm text-slate-600 leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all">
                      {mentor.data.bio}
                    </p>

                    <div class="flex flex-wrap gap-2 mt-4">
                      {mentor.data.linkedin && (
                        <a
                          href={mentor.data.linkedin}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                          </svg>
                          LinkedIn
                        </a>
                      )}

                      {mentor.data.github && (
                        <a
                          href={mentor.data.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                          </svg>
                          GitHub
                        </a>
                      )}

                      {mentor.data.email && (
                        <a
                          href={`mailto:${mentor.data.email}`}
                          class="inline-flex items-center px-2.5 py-1.5 text-xs font-medium text-slate-600 bg-slate-100 rounded hover:bg-slate-200 transition-colors"
                        >
                          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                          </svg>
                          Email
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </div>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>

        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
