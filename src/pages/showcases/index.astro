---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Showcases" description="Jelajahi proyek-proyek inovatif dari mahasiswa CCIT Venture Studio">
  <Navbar />
  
  <main class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-mono text-indigo-600 font-medium mb-4">PROJECT SHOWCASES</p>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Proyek Mahasiswa
        </h1>
      </div>

       <div class="text-center py-20">
        <div class="w-24 h-24 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-12 h-12 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Batch Pertama Sedang Berjalan</h3>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
          Showcase proyek akan ditampilkan setelah program demo day selesai. 
          Nantikan karya terbaik dari tim-tim batch pertama kami.
        </p>
        <a href="/batches" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors duration-200">
          Lihat Info Batch
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>
        
        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
