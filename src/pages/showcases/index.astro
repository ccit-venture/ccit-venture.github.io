---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getCollection } from 'astro:content';

const showcases = await getCollection('showcases');
---

<Layout title="Showcases" description="Jelajahi proyek-proyek inovatif dari mahasiswa CCIT Venture Studio">
  <Navbar />
  
  <main class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-sm font-mono text-indigo-600 font-medium mb-4">PROJECT SHOWCASES</p>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Proyek Mahasiswa
        </h1>
        
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Karya-karya terbaik dari program inkubasi CCIT Venture Studio. 
          Setiap proyek merupakan hasil kolaborasi intensif tim mahasiswa 
          dengan bimbingan mentor berpengalaman.
        </p>
      </div>

      {showcases.length === 0 ? (
        <div class="text-center py-20">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Belum Ada Proyek</h3>
          <p class="text-slate-600">Proyek-proyek akan segera ditampilkan di sini.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {showcases.map((project) => (
            <div class="bg-white border border-slate-200 rounded-lg shadow-sm p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium font-mono bg-blue-100 text-blue-800">
                  {project.data.jurusan}
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium font-mono bg-yellow-100 text-yellow-800">
                  {project.data.status}
                </span>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{project.data.productName}</h3>
              <p class="text-slate-600 text-sm font-medium mb-3">{project.data.tagline}</p>
              {project.data.description && (
                <p class="text-slate-500 text-sm mb-4">{project.data.description.slice(0, 100)}...</p>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </main>

  <footer class="bg-slate-50 border-t border-slate-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="flex items-center space-x-2 mb-4 md:mb-0">
          <span class="text-xl font-bold text-indigo-600">CCIT</span>
          <span class="text-xl font-semibold text-slate-900">Venture Studio</span>
        </div>
        
        <p class="text-slate-500 text-sm">
          2026 CCIT Venture Studio. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
